{
  "$schema": "https://calm.finos.org/release/1.0/meta/calm.json",
  "$id": "https://raw.githubusercontent.com/your-org/calm-patterns/main/patterns/mcp-pattern",
  "title": "Model Context Protocol (MCP) Architecture Pattern",
  "description": "A pattern for MCP-based architectures with client-server interactions and secure service deployments",
  "type": "object",
  "properties": {
    "nodes": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/node",
          "properties": {
            "unique-id": {
              "const": "mcp-client"
            },
            "name": {
              "const": "Claude"
            },
            "description": {
              "const": "MCP Client for querying for reports"
            },
            "node-type": {
              "const": "mcp-client"
            }
          },
          "required": ["unique-id", "name", "description", "node-type"]
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/node",
          "properties": {
            "unique-id": {
              "const": "mcp-server"
            },
            "name": {
              "const": "Reports MCP Server"
            },
            "description": {
              "const": "MCP Server that presents tools for reviewing operational reports for the week"
            },
            "node-type": {
              "const": "service"
            },
            "interfaces": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                {
                  "$ref": "#/defs/container-image-interface",
                  "properties": {
                    "unique-id": {
                      "const": "mcp-server-image"
                    }
                  }
                },
                {
                  "$ref": "#/defs/port-interface",
                  "properties": {
                    "unique-id": {
                      "const": "mcp-server-port"
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/node",
          "properties": {
            "unique-id": {
              "const": "reports-api"
            },
            "name": {
              "const": "Reports API"
            },
            "description": {
              "const": "API for accessing operational reports raised by the team"
            },
            "node-type": {
              "const": "service"
            },
            "interfaces": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                {
                  "$ref": "#/defs/container-image-interface",
                  "properties": {
                    "unique-id": {
                      "const": "reports-api-image"
                    }
                  }
                },
                {
                  "$ref": "#/defs/port-interface",
                  "properties": {
                    "unique-id": {
                      "const": "reports-api-port"
                    }
                  }
                }
              ]
            }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/node",
          "properties": {
            "unique-id": {
              "const": "secret-api"
            },
            "name": {
              "const": "Secret API"
            },
            "description": {
              "const": "Deployed API that should not be available to the MCP Server"
            },
            "node-type": {
              "const": "service"
            },
            "interfaces": {
              "type": "array",
              "minItems": 2,
              "maxItems": 2,
              "prefixItems": [
                {
                  "$ref": "#/defs/container-image-interface",
                  "properties": {
                    "unique-id": {
                      "const": "secret-api-image"
                    }
                  }
                },
                {
                  "$ref": "#/defs/port-interface",
                  "properties": {
                    "unique-id": {
                      "const": "secret-api-port"
                    }
                  }
                }
              ]
            },
            "controls": {
              "$ref": "https://calm.finos.org/release/1.0/meta/control.json#/defs/controls",
              "properties": {
                "security": {
                  "type": "object",
                  "properties": {
                    "description": {
                      "const": "Lock down an individual POD workload"
                    },
                    "requirements": {
                      "type": "array",
                      "minItems": 1,
                      "maxItems": 1,
                      "prefixItems": [
                        {
                          "$ref": "https://calm.finos.org/release/1.0/meta/control.json#/defs/control-detail",
                          "properties": {
                            "requirement-url": {
                              "const": "https://calm.finos.org/workshop/controls/micro-segmentation.requirement.json"
                            },
                            "config-url": {
                              "const": "https://calm.finos.org/workshop/controls/micro-segmentation.config.json"
                            }
                          }
                        }
                      ]
                    }
                  }
                }
              }
            }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/node",
          "properties": {
            "unique-id": {
              "const": "k8s-cluster"
            },
            "name": {
              "const": "Kubernetes Cluster"
            },
            "description": {
              "const": "Kubernetes Cluster with network policy rules enabled"
            },
            "node-type": {
              "const": "system"
            }
          }
        }
      ]
    },
    "relationships": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "prefixItems": [
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/relationship",
          "properties": {
            "unique-id": {
              "const": "mcp-client-mcp-server"
            },
            "description": {
              "const": "Interactions with MCP client and the MCP server"
            },
            "protocol": {
              "const": "HTTPS"
            },
            "relationship-type": {
              "const": {
                "connects": {
                  "source": {
                    "node": "mcp-client"
                  },
                  "destination": {
                    "node": "mcp-server"
                  }
                }
              }
            }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/relationship",
          "properties": {
            "unique-id": {
              "const": "mcp-server-reports-api"
            },
            "description": {
              "const": "Requests report data from the API on behalf of the tool"
            },
            "protocol": {
              "const": "mTLS"
            },
            "relationship-type": {
              "const": {
                "connects": {
                  "source": {
                    "node": "mcp-server"
                  },
                  "destination": {
                    "node": "reports-api"
                  }
                }
              }
            }
          }
        },
        {
          "$ref": "https://calm.finos.org/release/1.0/meta/core.json#/defs/relationship",
          "properties": {
            "unique-id": {
              "const": "deployed-in-k8s-cluster"
            },
            "description": {
              "const": "Components deployed on the k8s cluster"
            },
            "relationship-type": {
              "const": {
                "deployed-in": {
                  "container": "k8s-cluster",
                  "nodes": [
                    "mcp-server",
                    "reports-api",
                    "secret-api"
                  ]
                }
              }
            }
          }
        }
      ]
    }
  },
  "required": [
    "nodes",
    "relationships"
  ],
  "defs": {
    "container-image-interface": {
      "$ref": "https://calm.finos.org/release/1.0/meta/interface.json#/defs/interface-type",
      "type": "object",
      "properties": {
        "image": {
          "type": "string"
        }
      },
      "required": [
        "image"
      ]
    },
    "port-interface": {
      "$ref": "https://calm.finos.org/release/1.0/meta/interface.json#/defs/interface-type",
      "type": "object",
      "properties": {
        "port": {
          "type": "integer"
        }
      },
      "required": [
        "port"
      ]
    }
  }
}